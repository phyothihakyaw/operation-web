# --- Learnwu API -------------------------------------------------------------
# Leave both empty to run the app fully on built-in sample data (no backend).

# Recommended: same-origin proxy mode (avoids CORS entirely).
# The browser calls /api/learnwu/v1/* and the Next.js server forwards to
# API_PROXY_TARGET (server-only, never exposed to the browser).
# The access token is kept in an HttpOnly cookie set by the proxy — it never
# touches client-side JavaScript or localStorage.
NEXT_PUBLIC_API_URL=/api/learnwu/v1
API_PROXY_TARGET=https://api.dev.learnwu.com

# Alternative: direct mode — point the browser straight at the API.
# Requires the API's CORS policy to allow this app's origin, and the API's
# access_token cookie to be usable cross-site (it isn't in the current
# deployment model — SameSite=Strict — so this mode is not recommended).
# NEXT_PUBLIC_API_URL=https://api.dev.learnwu.com/v1
